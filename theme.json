{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "paper",
					"color": "#f3efe6",
					"name": "Paper"
				},
				{
					"slug": "card",
					"color": "#faf7f0",
					"name": "Card"
				},
				{
					"slug": "ink",
					"color": "#16150f",
					"name": "Ink"
				},
				{
					"slug": "ink-soft",
					"color": "#26251d",
					"name": "Ink Soft"
				},
				{
					"slug": "ink-muted",
					"color": "#3a382e",
					"name": "Ink Muted"
				},
				{
					"slug": "ink-faint",
					"color": "#4a483d",
					"name": "Ink Faint"
				},
				{
					"slug": "mono",
					"color": "#6b675c",
					"name": "Mono"
				},
				{
					"slug": "mono-dim",
					"color": "#8a8474",
					"name": "Mono Dim"
				},
				{
					"slug": "green-deep",
					"color": "#3c5a3a",
					"name": "Green Deep"
				},
				{
					"slug": "green-phosphor",
					"color": "#97C148",
					"name": "Green Phosphor"
				},
				{
					"slug": "green-pale",
					"color": "#dee5b8",
					"name": "Green Pale"
				},
				{
					"slug": "green-chipbg",
					"color": "#eef3e6",
					"name": "Green Chip Background"
				},
				{
					"slug": "green-readout",
					"color": "#c8e6a0",
					"name": "Green Readout"
				},
				{
					"slug": "rust",
					"color": "#b9762f",
					"name": "Rust"
				},
				{
					"slug": "line",
					"color": "#ddd7c9",
					"name": "Line"
				},
				{
					"slug": "line-2",
					"color": "#d8d2c4",
					"name": "Line 2"
				},
				{
					"slug": "line-3",
					"color": "#cbc4b4",
					"name": "Line 3"
				},
				{
					"slug": "warm-mid",
					"color": "#ede7d8",
					"name": "Warm Mid"
				},
				{
					"slug": "placeholder",
					"color": "#e7e0d1",
					"name": "Placeholder"
				},
				{
					"slug": "footer",
					"color": "#0f0e0a",
					"name": "Footer"
				},
				{
					"slug": "selection",
					"color": "#cfe0c9",
					"name": "Selection"
				},
				{
					"slug": "link-color",
					"color": "#2f6b7a",
					"name": "Link"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Archivo, sans-serif",
					"name": "Archivo",
					"slug": "archivo",
					"fontFace": [
						{
							"fontFamily": "Archivo",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/archivo/archivo-500.woff2"]
						},
						{
							"fontFamily": "Archivo",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/archivo/archivo-600.woff2"]
						},
						{
							"fontFamily": "Archivo",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/archivo/archivo-700.woff2"]
						},
						{
							"fontFamily": "Archivo",
							"fontWeight": "800",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/archivo/archivo-800.woff2"]
						},
						{
							"fontFamily": "Archivo",
							"fontWeight": "900",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/archivo/archivo-900.woff2"]
						}
					]
				},
				{
					"fontFamily": "Newsreader, serif",
					"name": "Newsreader",
					"slug": "newsreader",
					"fontFace": [
						{
							"fontFamily": "Newsreader",
							"fontWeight": "300",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/newsreader/newsreader-300.woff2"]
						},
						{
							"fontFamily": "Newsreader",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/newsreader/newsreader-400.woff2"]
						},
						{
							"fontFamily": "Newsreader",
							"fontWeight": "400",
							"fontStyle": "italic",
							"src": ["file:./assets/fonts/newsreader/newsreader-400-italic.woff2"]
						},
						{
							"fontFamily": "Newsreader",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/newsreader/newsreader-500.woff2"]
						},
						{
							"fontFamily": "Newsreader",
							"fontWeight": "500",
							"fontStyle": "italic",
							"src": ["file:./assets/fonts/newsreader/newsreader-500-italic.woff2"]
						},
						{
							"fontFamily": "Newsreader",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/newsreader/newsreader-600.woff2"]
						}
					]
				},
				{
					"fontFamily": "'Spline Sans Mono', monospace",
					"name": "Spline Sans Mono",
					"slug": "mono",
					"fontFace": [
						{
							"fontFamily": "Spline Sans Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/spline-sans-mono/spline-sans-mono-400.woff2"]
						},
						{
							"fontFamily": "Spline Sans Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/spline-sans-mono/spline-sans-mono-500.woff2"]
						},
						{
							"fontFamily": "Spline Sans Mono",
							"fontWeight": "600",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/spline-sans-mono/spline-sans-mono-600.woff2"]
						}
					]
				},
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Sans",
					"slug": "system-sans"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.8125rem",
					"name": "Small"
				},
				{
					"slug": "label",
					"size": "0.8125rem",
					"name": "Label"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "body",
					"size": "1.25rem",
					"name": "Body"
				},
				{
					"slug": "standfirst",
					"size": "1.4rem",
					"name": "Standfirst"
				},
				{
					"slug": "h3",
					"size": "1.375rem",
					"name": "H3"
				},
				{
					"slug": "h2",
					"size": "clamp(1.6rem, 3vw, 2.4rem)",
					"name": "H2"
				},
				{
					"slug": "hero",
					"size": "clamp(2.6rem, 6vw, 5.25rem)",
					"name": "Hero"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink-soft)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--newsreader)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "1.62"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--50)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "800"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "900",
					"fontSize": "var(--wp--preset--font-size--hero)",
					"lineHeight": "0.98",
					"letterSpacing": "-2px"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "800",
					"fontSize": "var(--wp--preset--font-size--h2)",
					"lineHeight": "1.05",
					"letterSpacing": "-1px"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--h3)",
					"lineHeight": "1.3",
					"letterSpacing": "-0.3px"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "700",
					"fontSize": "1.125rem"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--link-color)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--ink)"
					}
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "700",
					"fontSize": "0.875rem",
					"letterSpacing": "0.5px"
				},
				"color": {
					"background": "var(--wp--preset--color--green-deep)",
					"text": "var(--wp--preset--color--paper)"
				},
				"border": {
					"radius": "0",
					"width": "0"
				},
				"spacing": {
					"padding": {
						"top": "0.9375rem",
						"right": "1.875rem",
						"bottom": "0.9375rem",
						"left": "1.875rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--ink)",
						"text": "var(--wp--preset--color--paper)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "0.8125rem",
					"textTransform": "uppercase",
					"letterSpacing": "0.5px"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-muted)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--archivo)",
					"fontWeight": "800"
				},
				"color": {
					"text": "var(--wp--preset--color--ink)"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "uppercase",
					"letterSpacing": "1px"
				},
				"color": {
					"text": "var(--wp--preset--color--mono)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "uppercase",
					"letterSpacing": "1px"
				},
				"color": {
					"text": "var(--wp--preset--color--mono)"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--newsreader)",
					"fontSize": "1.1rem",
					"lineHeight": "1.55"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-faint)"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)"
				},
				"color": {
					"background": "var(--wp--preset--color--card)",
					"text": "var(--wp--preset--color--ink)"
				},
				"border": {
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--line)"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--newsreader)",
					"fontStyle": "italic",
					"fontSize": "1.3rem"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-muted)"
				},
				"border": {
					"width": "0 0 0 3px",
					"style": "solid",
					"color": "var(--wp--preset--color--green-deep)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--line)"
				}
			},
			"core/query-pagination": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "uppercase",
					"letterSpacing": "1px"
				},
				"color": {
					"text": "var(--wp--preset--color--ink-muted)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-home",
			"title": "Homepage",
			"postTypes": ["page"]
		},
		{
			"name": "page-services",
			"title": "Services",
			"postTypes": ["page"]
		},
		{
			"name": "page-about",
			"title": "About",
			"postTypes": ["page"]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": ["page"]
		},
		{
			"name": "page-georgia-runoffs",
			"title": "Case Study: Georgia Runoffs",
			"postTypes": ["page"]
		},
		{
			"name": "page-boundary-estimation",
			"title": "Case Study: Boundary Estimation",
			"postTypes": ["page"]
		},
		{
			"name": "page-polling-ethnography",
			"title": "Case Study: Polling as Ethnography",
			"postTypes": ["page"]
		}
	]
}
