{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "780px",
			"wideSize": "1140px"
		},
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#97C148",
					"name": "Signal Green"
				},
				{
					"slug": "primary-bright",
					"color": "#a8d454",
					"name": "Signal Bright"
				},
				{
					"slug": "accent",
					"color": "#dee583",
					"name": "Signal Dim"
				},
				{
					"slug": "surface",
					"color": "#0c0c0c",
					"name": "Surface"
				},
				{
					"slug": "surface-raised",
					"color": "#141414",
					"name": "Surface Raised"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "grey-100",
					"color": "#F5F5F5",
					"name": "Grey 100"
				},
				{
					"slug": "grey-400",
					"color": "#999999",
					"name": "Grey 400"
				},
				{
					"slug": "grey-600",
					"color": "#666666",
					"name": "Grey 600"
				},
				{
					"slug": "grey-800",
					"color": "#1e1e1e",
					"name": "Grey 800"
				},
				{
					"slug": "text-primary",
					"color": "#e0e0e0",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#a0a0a0",
					"name": "Text Secondary"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
					"name": "Inter",
					"slug": "body"
				},
				{
					"fontFamily": "'JetBrains Mono', 'SF Mono', 'Fira Code', 'Roboto Mono', monospace",
					"name": "Mono",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.8125rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.125rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "1.5rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "2.25rem",
					"name": "2X Large"
				},
				{
					"slug": "hero",
					"size": "clamp(2.5rem, 5vw, 4.5rem)",
					"name": "Hero"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7",
			"fontWeight": "400"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--50)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "700"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--hero)",
					"fontWeight": "800",
					"lineHeight": "1.1",
					"letterSpacing": "-0.03em"
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.3",
					"letterSpacing": "-0.01em"
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400",
					"textTransform": "uppercase",
					"letterSpacing": "0.1em"
				},
				"color": {
					"text": "var(--wp--preset--color--grey-400)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-bright)"
					}
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": {
					"background": "transparent",
					"text": "var(--wp--preset--color--primary)"
				},
				"border": {
					"radius": "0",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--primary)"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "2rem",
						"bottom": "0.75rem",
						"left": "2rem"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em"
				},
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": {
					"text": "var(--wp--preset--color--grey-600)"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "0.875rem"
				},
				"color": {
					"background": "var(--wp--preset--color--black)",
					"text": "var(--wp--preset--color--primary)"
				},
				"border": {
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--grey-800)"
				}
			},
			"core/quote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400",
					"fontStyle": "normal"
				},
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				},
				"border": {
					"width": "0 0 0 2px",
					"style": "solid",
					"color": "var(--wp--preset--color--primary)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--grey-800)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-home",
			"title": "Homepage",
			"postTypes": ["page"]
		},
		{
			"name": "page-services",
			"title": "Services",
			"postTypes": ["page"]
		},
		{
			"name": "page-about",
			"title": "About",
			"postTypes": ["page"]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": ["page"]
		}
	]
}
